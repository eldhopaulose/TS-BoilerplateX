# ─── Server ───────────────────────────────────────
PORT=3000
NODE_ENV=development

# ─── Logging ──────────────────────────────────────
LOG_LEVEL=debug

# ─── Rate Limiting ────────────────────────────────
RATE_LIMIT_WINDOW_MS=900000
RATE_LIMIT_MAX=100
STRICT_RATE_LIMIT_WINDOW_MS=900000
STRICT_RATE_LIMIT_MAX=10
